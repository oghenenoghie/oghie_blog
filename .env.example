# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Required for the /create-post command (Claude → Sanity workflow)
# Get this from: Sanity Studio → Manage → API → Tokens → Add API token (Editor or higher)
SANITY_WRITE_TOKEN=sk...your_write_token_here

# Unsplash (image fallback for news articles with no GNews image)
# Get a free key at https://unsplash.com/developers → "New Application"
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
